# ==================== AI Provider ====================
# Options: kimi | deepseek | gemini
AI_PROVIDER=kimi

# ==================== Provider Keys ====================
KIMI_API_KEY=your-kimi-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
GEMINI_API_KEY=your-gemini-api-key

# ==================== Runtime Mode ====================
USE_MOCK=false

# ==================== Main API & CORS ====================
CAMPUS_JOB_API_URL=http://localhost:3001/api/v1
CORS_ORIGINS=http://localhost:4200,http://localhost:4202,http://localhost:4204,http://localhost:8000
