# ==================== Database (MySQL) ====================
DB_NAME=campus_job_platform
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306

# ==================== Server ====================
PORT=3001
NODE_ENV=development
PUBLIC_SERVER_ORIGIN=http://localhost:3001

# Comma-separated origins allowed by CORS
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:4202,http://localhost:4204

# ==================== JWT ====================
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=24h

# ==================== AI Service ====================
AI_SERVICE_URL=http://localhost:8000
