{
  "name": "campus-job-platform",
  "version": "1.0.0",
  "description": "校园智能兼职服务平台后端",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "db:sync": "node scripts/sync-database.js",
    "db:drop": "node scripts/drop-database.js",
    "db:seed-demo": "node scripts/reset-demo-data.js",
    "lint": "eslint . --ext .js --ignore-pattern node_modules --ignore-pattern coverage --ignore-pattern dist --ignore-pattern '*.err' --ignore-pattern package-lock.json",
    "lint:fix": "eslint . --ext .js --fix --ignore-pattern node_modules --ignore-pattern coverage --ignore-pattern dist --ignore-pattern '*.err' --ignore-pattern package-lock.json"
  },
  "keywords": [
    "nodejs",
    "express",
    "sequelize",
    "mysql",
    "campus-job-platform"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "mysql2": "^3.22.0",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "*.js",
      "config/**/*.js",
      "controllers/**/*.js",
      "middlewares/**/*.js",
      "models/**/*.js",
      "routes/**/*.js",
      "services/**/*.js",
      "utils/**/*.js",
      "!server.js",
      "!scripts/**/*.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
